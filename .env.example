# ==============================================================================
# JS Cartographer Environment Configuration (Example)
# Rename this file to .env and adjust variables to fit your environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Local Dashboard / Visualizer Server Configuration
# ------------------------------------------------------------------------------
# The port on which the Express server and local explorer dashboard will run.
# CLI argument '-p' or '--port' takes precedence over this option.
PORT=3000

# ------------------------------------------------------------------------------
# 2. Pipeline Execution Output Configurations
# ------------------------------------------------------------------------------
# Default output directory for cleaned code, metadata sidecars, and global graphs.
# CLI argument '-o' or '--output' takes precedence over this option.
DEFAULT_OUTPUT_DIR=./dist-output

# ------------------------------------------------------------------------------
# 3. LLM Provider Configurations (Cloud-First Humanization)
# ------------------------------------------------------------------------------
# The active provider to use for semantic variable/function renaming.
# Supported options:
#   - heuristic  : Local offline naming using regex and expression contexts (No API keys required)
#   - gemini     : Google Gemini API (Requires GEMINI_API_KEY)
#   - openai     : OpenAI API (Requires OPENAI_API_KEY)
#   - openrouter : OpenRouter API (Requires OPENROUTER_API_KEY)
#   - local      : Local model execution (Requires LOCAL_LLM_PATH)
LLM_PROVIDER=heuristic

# The model identifier to query. Keep blank to use provider defaults.
# E.g., gemini-1.5-flash, gpt-4o, etc.
LLM_MODEL=

# ------------------------------------------------------------------------------
# 4. LLM Provider Credentials
# ------------------------------------------------------------------------------
# Google Gemini API Key
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key
# Get one at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API Key
# Get one at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------------------------
# 5. Local LLM Configuration (Optional)
# ------------------------------------------------------------------------------
# Absolute or relative path to a local GGUF model file (used when LLM_PROVIDER=local)
LOCAL_LLM_PATH=./models/llama-3-8b.gguf
